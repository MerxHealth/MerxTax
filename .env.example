# Application
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_PRICE_SOLO_MONTHLY=price_xxx
NEXT_PUBLIC_PRICE_SOLO_ANNUAL=price_xxx
NEXT_PUBLIC_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_PRICE_PRO_ANNUAL=price_xxx
NEXT_PUBLIC_PRICE_AGENT_MONTHLY=price_xxx
NEXT_PUBLIC_PRICE_AGENT_ANNUAL=price_xxx

# HMRC
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk
HMRC_CLIENT_ID=your_hmrc_client_id
HMRC_CLIENT_SECRET=your_hmrc_client_secret
HMRC_REDIRECT_URI=https://your-domain.com/auth/callback
HMRC_SANDBOX=true

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_PUBLIC_BASE_URL=https://assets.your-domain.com

# Optional integrations
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
